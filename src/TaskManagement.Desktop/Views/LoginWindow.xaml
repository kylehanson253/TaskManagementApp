<Window x:Class="TaskManagement.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager — Login" Height="460" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#BBCCDD" ShadowDepth="2" BlurRadius="12" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="40,30">
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Task Manager" FontSize="22" FontWeight="Bold"
                           Foreground="#1E3A5F" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to your account" FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Email" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Password" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" FontSize="13" Padding="8,6"
                             BorderBrush="#D1D5DB" BorderThickness="1"
                             Margin="0,0,0,20"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,0,0,12"/>

                <Button Content="{Binding IsLoading, Converter={StaticResource LoadingConverter}}"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
