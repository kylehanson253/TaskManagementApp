{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=taskmanagement.db"
  },
  "JwtSettings": {
    "Secret": "TaskManagementApp-SuperSecretKey-ChangeInProduction-32chars!!",
    "Issuer": "TaskManagementApp",
    "Audience": "TaskManagementApp.Clients",
    "ExpiryMinutes": "10"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
